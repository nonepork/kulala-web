{
	"displayName": "Kulala HTTP",
	"fileTypes": ["http", "rest"],
	"name": "http",
	"scopeName": "source.http",
	"embeddedLangs": ["shellscript", "json", "xml", "graphql", "javascript", "lua", "typescript"],
	"patterns": [
		{ "include": "#request-separator" },
		{ "include": "#pre-request-script" },
		{ "include": "#response-handler" },
		{ "include": "#response-redirect" },
		{ "include": "#curl-request" },
		{ "include": "#json-body" },
		{ "include": "#xml-body" },
		{ "include": "#graphql-body" },
		{ "include": "#metadata" },
		{ "include": "#comments" },
		{ "include": "#variable-declaration" },
		{ "include": "#commands" },
		{ "include": "#multipart-boundary" },
		{ "include": "#external-body" },
		{ "include": "#variables" },
		{ "include": "#query-param" },
		{ "include": "#headers" },
		{ "include": "#request-line" },
		{ "include": "#response-line" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"match": "^\\s*#+.*$",
					"name": "comment.line.sharp.http"
				},
				{
					"match": "^\\s*//.*$",
					"name": "comment.line.double-slash.http"
				}
			]
		},
		"commands": {
			"patterns": [
				{
					"begin": "^(run|import)\\b",
					"beginCaptures": {
						"1": { "name": "keyword.control.http" }
					},
					"end": "$",
					"name": "meta.command.http",
					"patterns": [
						{ "include": "#variables" },
						{
							"match": "[^\\s(),]+",
							"name": "string.other.http"
						},
						{
							"match": "@",
							"name": "punctuation.definition.block.tag.metadata"
						},
						{
							"match": "=",
							"name": "keyword.operator.http"
						}
					]
				}
			]
		},
		"curl-request": {
			"begin": "^\\s*(?=curl)",
			"end": "^\\s*(#{3,}.*?)?\\s*$",
			"endCaptures": {
				"0": { "name": "comment.line.sharp.http" }
			},
			"name": "http.request.curl",
			"patterns": [{ "include": "source.shell" }]
		},
		"external-body": {
			"match": "^<\\s+([^\\s{%].*)$",
			"captures": {
				"0": { "name": "meta.external-body.http" },
				"1": {
					"name": "support.class.http",
					"patterns": [{ "include": "#variables" }]
				}
			}
		},
		"graphql-body": {
			"patterns": [
				{
					"begin": "\\s*(?=(query|mutation))",
					"end": "^\\s*(#{3,}.*?)?\\s*$",
					"endCaptures": {
						"0": { "name": "comment.line.sharp.http" }
					},
					"name": "http.request.body.graphql",
					"patterns": [{ "include": "source.graphql" }]
				},
				{
					"begin": "\\s*(?=(query|mutation))",
					"end": "^\\{\\s*$",
					"name": "http.request.body.graphql",
					"patterns": [{ "include": "source.graphql" }]
				}
			]
		},
		"headers": {
			"match": "^([-\\w]+)\\s*(:)\\s*([^/].*?)\\s*$",
			"captures": {
				"1": { "name": "entity.name.tag.http" },
				"2": { "name": "keyword.other.http" },
				"3": {
					"name": "string.other.http",
					"patterns": [{ "include": "#variables" }]
				}
			},
			"name": "http.headers"
		},
		"inline-script-content": {
			"patterns": [
				{
					"begin": "lang=lua\\b",
					"end": "\\z",
					"beginCaptures": {
						"0": { "name": "support.type" }
					},
					"contentName": "source.lua",
					"patterns": [{ "include": "source.lua" }]
				},
				{
					"begin": "lang=ts\\b",
					"end": "\\z",
					"beginCaptures": {
						"0": { "name": "support.type" }
					},
					"contentName": "source.ts",
					"patterns": [{ "include": "source.ts" }]
				},
				{ "include": "source.js" }
			]
		},
		"json-body": {
			"patterns": [
				{
					"begin": "^\\s*\\{",
					"end": "^\\}\\s*$",
					"name": "http.request.body.json",
					"patterns": [{ "include": "source.json" }]
				},
				{
					"begin": "^\\s*\\[",
					"end": "^\\]\\s*$",
					"name": "http.request.body.json",
					"patterns": [{ "include": "source.json" }]
				}
			]
		},
		"metadata": {
			"patterns": [
				{
					"match": "^\\s*#+\\s+((@)[\\w-]+)\\s*(?:=\\s*(.*))?$",
					"captures": {
						"1": { "name": "entity.other.attribute-name" },
						"2": { "name": "punctuation.definition.block.tag.metadata" },
						"3": { "name": "string.other.http" }
					},
					"name": "comment.line.sharp.http"
				},
				{
					"match": "^\\s*//+\\s+((@)[\\w-]+)\\s*(?:=\\s*(.*))?$",
					"captures": {
						"1": { "name": "entity.other.attribute-name" },
						"2": { "name": "punctuation.definition.block.tag.metadata" },
						"3": { "name": "string.other.http" }
					},
					"name": "comment.line.double-slash.http"
				},
				{
					"match": "^\\s*#+\\s+((@)name)\\s+([^.\\s]+)$",
					"captures": {
						"1": { "name": "entity.other.attribute-name" },
						"2": { "name": "punctuation.definition.block.tag.metadata" },
						"3": { "name": "entity.name.type.http" }
					},
					"name": "comment.line.sharp.http"
				},
				{
					"match": "^\\s*//+\\s+((@)name)\\s+([^.\\s]+)$",
					"captures": {
						"1": { "name": "entity.other.attribute-name" },
						"2": { "name": "punctuation.definition.block.tag.metadata" },
						"3": { "name": "entity.name.type.http" }
					},
					"name": "comment.line.double-slash.http"
				},
				{
					"match": "^\\s*#+\\s+((@)note)\\s*$",
					"captures": {
						"1": { "name": "entity.other.attribute-name" },
						"2": { "name": "punctuation.definition.block.tag.metadata" }
					},
					"name": "comment.line.sharp.http"
				},
				{
					"match": "^\\s*//+\\s+((@)note)\\s*$",
					"captures": {
						"1": { "name": "entity.other.attribute-name" },
						"2": { "name": "punctuation.definition.block.tag.metadata" }
					},
					"name": "comment.line.double-slash.http"
				},
				{
					"match": "^\\s*#+\\s+((@)prompt)\\s+(\\S+)(?:\\s+(.*))?\\s*$",
					"captures": {
						"1": { "name": "entity.other.attribute-name" },
						"2": { "name": "punctuation.definition.block.tag.metadata" },
						"3": { "name": "variable.other.http" },
						"4": { "name": "string.other.http" }
					},
					"name": "comment.line.sharp.http"
				},
				{
					"match": "^\\s*//+\\s+((@)prompt)\\s+(\\S+)(?:\\s+(.*))?\\s*$",
					"captures": {
						"1": { "name": "entity.other.attribute-name" },
						"2": { "name": "punctuation.definition.block.tag.metadata" },
						"3": { "name": "variable.other.http" },
						"4": { "name": "string.other.http" }
					},
					"name": "comment.line.double-slash.http"
				}
			]
		},
		"multipart-boundary": {
			"match": "^--([^\\s\\n\\r{][^\\n\\r]*?)(--)?\\s*$",
			"captures": {
				"0": { "name": "keyword.other.http" },
				"1": {
					"name": "string.other.http",
					"patterns": [{ "include": "#variables" }]
				}
			}
		},
		"pre-request-script": {
			"patterns": [
				{
					"begin": "^(<)(\\s+)(\\{%)",
					"end": "^%\\}\\s*$",
					"beginCaptures": {
						"1": { "name": "punctuation.special.http" },
						"3": { "name": "punctuation.definition.block.script.http" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.definition.block.script.http" }
					},
					"name": "meta.pre-request-script.http",
					"patterns": [{ "include": "#inline-script-content" }]
				},
				{
					"match": "^<\\s+([^\\s{%].*)$",
					"captures": {
						"0": { "name": "meta.external-body.http" },
						"1": {
							"name": "constant.numeric.http",
							"patterns": [{ "include": "#variables" }]
						}
					}
				}
			]
		},
		"protocol": {
			"patterns": [
				{
					"match": "(HTTP)/(\\d+\\.\\d+)",
					"captures": {
						"1": { "name": "keyword.other.http" },
						"2": { "name": "constant.numeric.http" }
					},
					"name": "http.version"
				}
			]
		},
		"query-param": {
			"patterns": [
				{
					"match": "^\\s*([#&?])([^=\\s]+)(?:=(.*))?$",
					"captures": {
						"1": { "name": "keyword.operator.http" },
						"2": {
							"name": "variable.parameter.http",
							"patterns": [{ "include": "#variables" }]
						},
						"3": {
							"name": "string.other.http",
							"patterns": [{ "include": "#variables" }]
						}
					},
					"name": "http.query"
				},
				{
					"match": "(#)([^\\s\\n\\r]+)",
					"captures": {
						"1": { "name": "keyword.operator.http" },
						"2": { "name": "string.regexp.http" }
					}
				}
			]
		},
		"request-line": {
			"match": "(?i)^(options|get|head|post|put|delete|trace|connect|patch|list|graphql|grpc|websocket|ws|wss|lock|unlock|propfind|proppatch|copy|move|mkcol|mkcalendar|acl|search)\\s+(.+?)(?:\\s+(HTTP/\\S+))?$",
			"captures": {
				"1": { "name": "keyword.control.http" },
				"2": {
					"name": "const.language.http",
					"patterns": [
						{ "include": "#variables" },
						{ "include": "#query-param" },
						{ "include": "#protocol" }
					]
				},
				"3": {
					"patterns": [{ "include": "#protocol" }]
				}
			},
			"name": "http.requestline"
		},
		"request-separator": {
			"match": "^#{3,}\\s*(.*?)$",
			"captures": {
				"0": { "name": "comment.line.sharp.http" },
				"1": { "name": "keyword.other.http" }
			}
		},
		"response-handler": {
			"patterns": [
				{
					"begin": "^(>)(\\s+)(\\{%)",
					"end": "^%\\}\\s*$",
					"beginCaptures": {
						"1": { "name": "punctuation.special.http" },
						"3": { "name": "punctuation.definition.block.script.http" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.definition.block.script.http" }
					},
					"name": "meta.response-handler-script.http",
					"patterns": [{ "include": "#inline-script-content" }]
				},
				{
					"match": "^(>)(\\s+)([^\\s{%].*)$",
					"captures": {
						"1": { "name": "punctuation.special.http" },
						"3": {
							"name": "constant.numeric.http",
							"patterns": [{ "include": "#variables" }]
						}
					},
					"name": "meta.response-handler.http"
				}
			]
		},
		"response-line": {
			"match": "(?i)^\\s*(HTTP/\\S+)\\s+([1-5]\\d{2})\\s*(.*)$",
			"captures": {
				"1": {
					"patterns": [{ "include": "#protocol" }]
				},
				"2": { "name": "constant.numeric.http" },
				"3": { "name": "string.other.http" }
			},
			"name": "http.responseLine"
		},
		"response-redirect": {
			"match": "^>>!?\\s+(.*)$",
			"captures": {
				"0": { "name": "meta.redirect.http" },
				"1": {
					"name": "support.class.http",
					"patterns": [{ "include": "#variables" }]
				}
			}
		},
		"variable-declaration": {
			"match": "^(@)([\\w.$\\[\\]-]+)\\s*(=)\\s*(.*)$",
			"captures": {
				"1": { "name": "punctuation.definition.block.tag.metadata" },
				"2": { "name": "variable.other.http" },
				"3": { "name": "keyword.operator.http" },
				"4": {
					"name": "string.other.http",
					"patterns": [{ "include": "#variables" }]
				}
			},
			"name": "http.filevariable"
		},
		"variables": {
			"patterns": [
				{
					"match": "\\{\\{\\s*([\\w.$\\[\\]()]+)\\s*\\}\\}",
					"captures": {
						"0": { "name": "meta.variable.http" },
						"1": { "name": "variable.other.http" }
					}
				}
			]
		},
		"xml-body": {
			"begin": "^\\s*<[A-Za-z!?]",
			"end": "^\\s*(#{3,}.*?)?\\s*$",
			"endCaptures": {
				"0": { "name": "comment.line.sharp.http" }
			},
			"name": "http.request.body.xml",
			"patterns": [{ "include": "text.xml" }]
		}
	}
}
