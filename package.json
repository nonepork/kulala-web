		"svelte-sitemap": "3.2.0",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.61.0",
		"unified": "11.0.5",
		"vite": "npm:@voidzero-dev/vite-plus-core@latest",
		"vite-plus": "latest",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
