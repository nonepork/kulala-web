		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "2.64.0",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/postcss": "4.3.0",
		"@tailwindcss/typography": "0.5.20",
		"@tailwindcss/vite": "4.3.0",
		"@types/node": "25.9.2",
		"daisyui": "5.5.23",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.19.0",
		"globals": "17.6.0",
